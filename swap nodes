class Solution {
public:
    ListNode* swapPairs(ListNode* head
        ListNode dummy(0, head);
        ListNode* prev = &dummy;


        while (prev->next != nullptr && prev->next->next != nullptr) {
            ListNode* first = prev->next;
            ListNode* second = prev->next->next;

            first->next = second->next;
            second->next = first;
            prev->next = second;

    
            prev = first;
        }

        return dummy.next;
    }
};
