#include <iostream>
using namespace std;

int main() {
    int N;
    
    // Loop 5 times to handle 5 separate lines of input
    for (int i = 0; i < 5; i++) {
        // Accept the integer N
        cin >> N;
        
        // Output the integer N on a new line
        cout << N << endl;
    }
    
    return 0;
}
