#include <iostream> 
using namespace std; 

int main() { 
    int n,i;
    scanf("%d",&n);
    int arr[n];
    for(i=0;i<n;i++)
        scanf("%d",&arr[i]);

    int maxCount = 0; 
	int index = -1; // sentinels 
	for(int i = 0; i < n; i++) {
	    int count = 0; 
		for(int j = 0; j < n; j++) { 
			if(arr[i] == arr[j]) 
			count++; 
		} 
		
		if(count > maxCount) {
			maxCount = count; 
			index = i; 
		} 
	} 
	
	
	if (maxCount > n/2) 
	    cout << arr[index] << endl; 
	
	else
		cout << "0" << endl; 
	return 0; 
} 
