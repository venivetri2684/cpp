#include <iostream>
using namespace std;

int main() {
    int t;
    // Read the number of test cases
    cin >> t;

    while (t--) {
        int A, B, C, D, E;
        
        // Read A and B from the first line, then C, D, and E from the second
        cin >> A >> B >> C >> D >> E;
        
        // Output all 5 integers on a single line separated by spaces
        cout << A << " " << B << " " << C << " " << D << " " << E << endl;
    }

    return 0;
}

