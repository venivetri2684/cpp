#include <stack>
#include <string>
#include <algorithm>

class Solution {
public:
    int longestValidParentheses(string s) {
        std::stack<int> st;
        st.push(-1); 
        int max_len = 0;

        for (int i = 0; i < s.length(); i++) {
            if (s[i] == '(') {
                st.push(i);
            } else {
                st.pop();
                if (st.empty()) {
                    
                    st.push(i);
                } else {
                    
                    max_len = std::max(max_len, i - st.top());
                }
            }
        }
        return max_len;
    }
};
