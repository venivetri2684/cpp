#include<iostream>
using namespace std;
int main()
{
    int size, max, min, flag = 0;
    cin>>size;
    if(size<=0||size>10||cin.fail())
    {
        cout<<"Invalid";
        return 0;
    }
    int arr[size];
    for (int i=0;i<size;i++)
    {
         cin>>arr[i];
    }
    max = arr[0];
    min = arr[0];
    for (int i=0;i<size;i++)
    {
        if(arr[i]>max)
            max= arr[i];
        if(arr[i]<min)
            min = arr[i];
    }
    cout<<"Max:"<<max<<endl<<"Min:"<<min;
    return 0;
}
